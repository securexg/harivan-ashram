---
import { Image } from "astro:assets";
import logo from "~/assets/aol-logo.png";
import { contact, links, site } from "~/data/site";

const year = new Date().getFullYear();
---

<!-- Wide ashram landscape banner above footer -->
<section aria-hidden="true" class="relative h-[40vh] min-h-[280px] overflow-hidden">
  <picture class="absolute inset-0 block h-full w-full">
    <source
      type="image/webp"
      srcset="/images/activities/navratri/photo-25-1024.webp 1024w, /images/activities/navratri/photo-25-1600.webp 1600w, /images/activities/navratri/photo-25-2400.webp 2400w"
      sizes="100vw"
    />
    <img
      src="/images/activities/navratri/photo-25.webp"
      alt=""
      class="h-full w-full object-cover object-center"
      loading="lazy"
      decoding="async"
    />
  </picture>
  <div class="absolute inset-0 bg-gradient-to-t from-cream-100 via-ink-700/30 to-ink-700/20"></div>
  <div class="relative z-10 flex h-full items-center justify-center px-6">
    <p class="h-display-italic text-center text-3xl text-white drop-shadow-[0_2px_24px_rgba(0,0,0,0.45)] md:text-5xl lg:text-6xl">
      Come, breathe, belong.
    </p>
  </div>
</section>

<footer class="relative bg-cream-100">
  <div class="container-x grid gap-12 py-16 md:grid-cols-12 md:gap-x-16 md:py-20">
    <div class="md:col-span-4">
      <div class="flex flex-col items-start gap-5">
        <Image
          src={logo}
          alt="The Art of Living"
          class="h-14 w-auto"
          widths={[160, 320]}
          sizes="160px"
          loading="lazy"
          format="webp"
        />
        <div class="space-y-1">
          <p class="font-serif text-2xl text-ink-700">Harivan Ashram</p>
          <p class="eyebrow">{site.tagline} · Tricity · North India</p>
        </div>
        <p class="lead max-w-md">
          Blessed by Pujya Gurudev Sri Sri Ravi Shankar ji. Eleven acres of forest
          near Chandigarh — a sanctuary for breath, meditation and seva.
        </p>
      </div>
    </div>

    <div class="grid gap-10 md:col-span-8 md:grid-cols-12 md:gap-x-8">
      <div class="md:col-span-4">
        <p class="eyebrow">Visit</p>
        <p class="mt-3 body-text text-sm leading-relaxed">
          {contact.addressFull}
        </p>
      </div>
      <div class="md:col-span-5">
        <p class="eyebrow">Reach us</p>
        <ul class="mt-3 space-y-2 body-text text-sm">
          <li>
            <a href={`tel:${contact.phoneIntl}`} class="hover:text-ink-700"
              >{contact.phone}</a
            >
          </li>
          <li>
            <a
              href={`https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(contact.whatsappMessage)}`}
              class="hover:text-ink-700">WhatsApp</a
            >
          </li>
          <li>
            <a
              href={`mailto:${contact.email}`}
              class="block break-all hover:text-ink-700"
            >{contact.email}</a>
          </li>
        </ul>
      </div>
      <div class="md:col-span-3">
        <p class="eyebrow">More</p>
        <ul class="mt-3 space-y-2 body-text text-sm">
          <li>
            <a href={links.artOfLiving} target="_blank" rel="noopener" class="hover:text-ink-700">artofliving.org</a>
          </li>
          <li>
            <a href={links.gurudev} target="_blank" rel="noopener" class="hover:text-ink-700">gurudev.artofliving.org</a>
          </li>
          <li>
            <a href="#support" class="hover:text-ink-700">Support the Ashram</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-ink-100">
    <div class="container-x flex flex-col gap-3 py-6 text-xs text-ink-300 md:flex-row md:items-center md:justify-between">
      <p>© {year} Harivan Ashram · The Art of Living</p>
      <p class="font-serif italic text-ink-300">Sanghachadwam · Jaigurudev</p>
    </div>
  </div>
</footer>
