---
/* Custom, branded translation widget.
   Embedded Google Translate is unreliable on mobile Safari/content blockers.
   The menu now uses Google's full translated-page endpoint for Hindi/Punjabi,
   while English returns to the canonical site URL.

   Two visual instances of the menu mount from this same component:
     · Desktop: inline pill in the site header (slot via header)
     · Mobile : floating bottom-right button

   This keeps the switch clean and avoids half-translated widget UI.
*/
---

<!-- Mobile floating button -->
<div class="notranslate fixed bottom-5 right-4 z-40 md:hidden" data-hv-translate-mobile translate="no">
  <button
    type="button"
    class="hv-translate-trigger notranslate inline-flex items-center gap-2 rounded-full border border-ink-100/60 bg-cream-50/95 px-4 py-2.5 font-sans text-[13px] font-medium tracking-[0.04em] text-ink-700 shadow-[0_18px_40px_-18px_rgba(24,21,15,0.35)] backdrop-blur"
    aria-haspopup="listbox"
    aria-expanded="false"
    translate="no"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-ink-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
    </svg>
    <span data-hv-translate-label>English</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <ul
    class="hv-translate-menu absolute bottom-full right-0 mb-2 hidden min-w-[160px] overflow-hidden rounded-2xl border border-ink-100/60 bg-cream-50/98 py-1 shadow-[0_30px_60px_-25px_rgba(24,21,15,0.45)] backdrop-blur"
    role="listbox"
    translate="no"
  >
    <li>
      <button type="button" data-lang="en" role="option" class="hv-translate-option notranslate flex w-full items-center justify-between px-4 py-2.5 text-left text-[13px] font-medium text-ink-700 hover:bg-cream-200" translate="no">
        English
        <span class="hv-translate-check text-saffron-500">✓</span>
      </button>
    </li>
    <li>
      <button type="button" data-lang="hi" role="option" class="hv-translate-option notranslate flex w-full items-center justify-between px-4 py-2.5 text-left text-[13px] font-medium text-ink-700 hover:bg-cream-200" translate="no">
        हिंदी
        <span class="hv-translate-check text-saffron-500">✓</span>
      </button>
    </li>
    <li>
      <button type="button" data-lang="pa" role="option" class="hv-translate-option notranslate flex w-full items-center justify-between px-4 py-2.5 text-left text-[13px] font-medium text-ink-700 hover:bg-cream-200" translate="no">
        ਪੰਜਾਬੀ
        <span class="hv-translate-check text-saffron-500">✓</span>
      </button>
    </li>
  </ul>
</div>

<style is:global>
  /* Hide every Google-injected UI piece */
  body { top: 0 !important; }
  .skiptranslate iframe,
  .goog-te-banner-frame,
  .goog-te-banner-frame.skiptranslate,
  .goog-tooltip,
  .goog-tooltip:hover,
  .goog-text-highlight,
  #goog-gt-tt {
    display: none !important;
    visibility: hidden !important;
    box-shadow: none !important;
  }
  #google_translate_element { display: none !important; }
  /* Suppress Google's body-shift hack that adds a 40px top margin */
  html, body { transform: none !important; }

  /* Hide the inline check ✓ next to non-active languages */
  .hv-translate-option:not([data-active="true"]) .hv-translate-check { visibility: hidden; }
  .hv-translate-option[data-active="true"] { background: var(--color-cream-200); }
</style>

<script>
  // Custom dropdown logic — supports multiple instances of the menu
  type Lang = "en" | "hi" | "pa";
  const LABELS: Record<Lang, string> = { en: "English", hi: "हिंदी", pa: "ਪੰਜਾਬੀ" };

  const clearGoogTransCookies = () => {
    const host = window.location.hostname;
    const domains = ["", host, `.${host}`].filter(Boolean);
    const paths = ["/", window.location.pathname || "/"];
    domains.forEach((domain) => {
      paths.forEach((path) => {
        document.cookie = `googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=${path}${domain ? `;domain=${domain}` : ""}`;
      });
    });
  };

  const canonicalUrl = () => {
    const loc = window.location.href;
    const url = new URL(loc);
    if (url.hostname.endsWith(".translate.goog")) {
      const orig = url.hostname.replace(/\.translate\.goog$/, "").replace(/-/g, ".");
      url.hostname = orig;
      url.searchParams.delete("_x_tr_sl");
      url.searchParams.delete("_x_tr_tl");
      url.searchParams.delete("_x_tr_hl");
      return url.toString();
    }
    if (url.hostname === "translate.google.com") {
      const u = url.searchParams.get("u");
      if (u) return u;
    }
    url.searchParams.delete("googtrans");
    return `${url.origin}${url.pathname}${url.search}${url.hash}`;
  };

  const translatedUrl = (lang: Exclude<Lang, "en">) => {
    const u = canonicalUrl();
    const host = new URL(u).hostname.replace(/\./g, "-");
    const translateHost = `${host}.translate.goog`;
    const url = new URL(u);
    url.hostname = translateHost;
    url.searchParams.set("_x_tr_sl", "en");
    url.searchParams.set("_x_tr_tl", lang);
    url.searchParams.set("_x_tr_hl", lang);
    return url.toString();
  };

  const reflectInUI = (lang: Lang) => {
    document.querySelectorAll<HTMLElement>("[data-hv-translate-label]").forEach((el) => {
      el.textContent = LABELS[lang];
    });
    document.querySelectorAll<HTMLButtonElement>(".hv-translate-option").forEach((opt) => {
      opt.dataset.active = opt.dataset.lang === lang ? "true" : "false";
    });
  };

  const apply = (lang: Lang) => {
    reflectInUI(lang);
    clearGoogTransCookies();
    if (lang === "en") {
      window.location.href = canonicalUrl();
      return;
    }
    window.location.href = translatedUrl(lang);
  };

  window.addEventListener("pageshow", () => {
    reflectInUI("en");
  });

  const wireTriggers = () => {
    document.querySelectorAll<HTMLElement>("[data-hv-translate-mobile], [data-hv-translate-desktop]").forEach((root) => {
      const trigger = root.querySelector<HTMLButtonElement>(".hv-translate-trigger");
      const menu = root.querySelector<HTMLUListElement>(".hv-translate-menu");
      if (!trigger || !menu) return;

      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const open = !menu.classList.contains("hidden");
        document.querySelectorAll<HTMLElement>(".hv-translate-menu").forEach((m) => m.classList.add("hidden"));
        if (!open) {
          menu.classList.remove("hidden");
          trigger.setAttribute("aria-expanded", "true");
        } else {
          trigger.setAttribute("aria-expanded", "false");
        }
      });

      menu.querySelectorAll<HTMLButtonElement>(".hv-translate-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          const lang = (opt.dataset.lang || "en") as Lang;
          apply(lang);
          menu.classList.add("hidden");
          trigger.setAttribute("aria-expanded", "false");
        });
      });
    });

    document.addEventListener("click", () => {
      document.querySelectorAll<HTMLElement>(".hv-translate-menu").forEach((m) => m.classList.add("hidden"));
      document.querySelectorAll<HTMLElement>(".hv-translate-trigger").forEach((t) => t.setAttribute("aria-expanded", "false"));
    });
  };

  // Init
  document.addEventListener("DOMContentLoaded", () => {
    wireTriggers();
    reflectInUI("en");
  });
</script>
