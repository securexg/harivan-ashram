---
/* Custom, branded translation widget.
   We render our own English / हिंदी / ਪੰਜਾਬੀ menu and quietly drive the
   official Google Translate engine in the background — no Google badge,
   no banner, no “Powered by” strip.

   Two visual instances of the menu mount from this same component:
     · Desktop: inline pill in the site header (slot via header)
     · Mobile : floating bottom-right button

   Under the hood there is one hidden #google_translate_element that does
   the actual work; both menus dispatch a `change` on `.goog-te-combo`.
*/
---

<!-- Hidden engine host for Google Translate -->
<div id="google_translate_element" class="hidden" aria-hidden="true"></div>

<!-- Mobile floating button -->
<div class="fixed bottom-5 right-4 z-40 md:hidden" data-hv-translate-mobile>
  <button
    type="button"
    class="hv-translate-trigger inline-flex items-center gap-2 rounded-full border border-ink-100/60 bg-cream-50/95 px-4 py-2.5 font-sans text-[13px] font-medium tracking-[0.04em] text-ink-700 shadow-[0_18px_40px_-18px_rgba(24,21,15,0.35)] backdrop-blur"
    aria-haspopup="listbox"
    aria-expanded="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-ink-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
      <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
    </svg>
    <span data-hv-translate-label>English</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <ul
    class="hv-translate-menu absolute bottom-full right-0 mb-2 hidden min-w-[160px] overflow-hidden rounded-2xl border border-ink-100/60 bg-cream-50/98 py-1 shadow-[0_30px_60px_-25px_rgba(24,21,15,0.45)] backdrop-blur"
    role="listbox"
  >
    <li>
      <button type="button" data-lang="en" role="option" class="hv-translate-option flex w-full items-center justify-between px-4 py-2.5 text-left text-[13px] font-medium text-ink-700 hover:bg-cream-200">
        English
        <span class="hv-translate-check text-saffron-500">✓</span>
      </button>
    </li>
    <li>
      <button type="button" data-lang="hi" role="option" class="hv-translate-option flex w-full items-center justify-between px-4 py-2.5 text-left text-[13px] font-medium text-ink-700 hover:bg-cream-200">
        हिंदी
        <span class="hv-translate-check text-saffron-500">✓</span>
      </button>
    </li>
    <li>
      <button type="button" data-lang="pa" role="option" class="hv-translate-option flex w-full items-center justify-between px-4 py-2.5 text-left text-[13px] font-medium text-ink-700 hover:bg-cream-200">
        ਪੰਜਾਬੀ
        <span class="hv-translate-check text-saffron-500">✓</span>
      </button>
    </li>
  </ul>
</div>

<style is:global>
  /* Hide every Google-injected UI piece */
  body { top: 0 !important; }
  .skiptranslate iframe,
  .goog-te-banner-frame,
  .goog-te-banner-frame.skiptranslate,
  .goog-tooltip,
  .goog-tooltip:hover,
  .goog-text-highlight,
  #goog-gt-tt {
    display: none !important;
    visibility: hidden !important;
    box-shadow: none !important;
  }
  #google_translate_element { display: none !important; }
  /* Suppress Google's body-shift hack that adds a 40px top margin */
  html, body { transform: none !important; }

  /* Hide the inline check ✓ next to non-active languages */
  .hv-translate-option:not([data-active="true"]) .hv-translate-check { visibility: hidden; }
  .hv-translate-option[data-active="true"] { background: var(--color-cream-200); }
</style>

<script is:inline>
  // Google Translate bootstrap
  window.googleTranslateElementInit = function () {
    if (!window.google || !window.google.translate) return;
    new window.google.translate.TranslateElement(
      {
        pageLanguage: "en",
        includedLanguages: "en,hi,pa",
        layout: window.google.translate.TranslateElement.InlineLayout.SIMPLE,
        autoDisplay: false,
      },
      "google_translate_element",
    );
  };
</script>
<script
  is:inline
  src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"
  defer></script>

<script>
  // Custom dropdown logic — supports multiple instances of the menu
  type Lang = "en" | "hi" | "pa";
  const LABELS: Record<Lang, string> = { en: "English", hi: "हिंदी", pa: "ਪੰਜਾਬੀ" };

  const KEY = "hv-lang";

  const setComboLanguage = (lang: Lang) => {
    const combo = document.querySelector<HTMLSelectElement>(".goog-te-combo");
    if (!combo) return false;
    combo.value = lang === "en" ? "" : lang;
    combo.dispatchEvent(new Event("change"));
    return true;
  };

  const reflectInUI = (lang: Lang) => {
    document.querySelectorAll<HTMLElement>("[data-hv-translate-label]").forEach((el) => {
      el.textContent = LABELS[lang];
    });
    document.querySelectorAll<HTMLButtonElement>(".hv-translate-option").forEach((opt) => {
      opt.dataset.active = opt.dataset.lang === lang ? "true" : "false";
    });
  };

  const apply = (lang: Lang, persist = true) => {
    if (persist) {
      try { localStorage.setItem(KEY, lang); } catch {}
    }
    reflectInUI(lang);
    if (lang === "en") {
      // Reset by stripping the googtrans cookie and reloading without google's overlay
      document.cookie = "googtrans=/en/en;path=/";
      document.cookie = "googtrans=;path=/;expires=Thu, 01 Jan 1970 00:00:00 GMT";
      const ok = setComboLanguage("en");
      if (!ok) window.location.reload();
      return;
    }
    // Try the live combo first; if Google hasn't finished bootstrapping, fall
    // back to the `googtrans` cookie + reload (the official documented approach).
    if (!setComboLanguage(lang)) {
      document.cookie = `googtrans=/en/${lang};path=/`;
      window.location.reload();
    }
  };

  const wireTriggers = () => {
    document.querySelectorAll<HTMLElement>("[data-hv-translate-mobile], [data-hv-translate-desktop]").forEach((root) => {
      const trigger = root.querySelector<HTMLButtonElement>(".hv-translate-trigger");
      const menu = root.querySelector<HTMLUListElement>(".hv-translate-menu");
      if (!trigger || !menu) return;

      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const open = !menu.classList.contains("hidden");
        document.querySelectorAll<HTMLElement>(".hv-translate-menu").forEach((m) => m.classList.add("hidden"));
        if (!open) {
          menu.classList.remove("hidden");
          trigger.setAttribute("aria-expanded", "true");
        } else {
          trigger.setAttribute("aria-expanded", "false");
        }
      });

      menu.querySelectorAll<HTMLButtonElement>(".hv-translate-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          const lang = (opt.dataset.lang || "en") as Lang;
          apply(lang);
          menu.classList.add("hidden");
          trigger.setAttribute("aria-expanded", "false");
        });
      });
    });

    document.addEventListener("click", () => {
      document.querySelectorAll<HTMLElement>(".hv-translate-menu").forEach((m) => m.classList.add("hidden"));
      document.querySelectorAll<HTMLElement>(".hv-translate-trigger").forEach((t) => t.setAttribute("aria-expanded", "false"));
    });
  };

  // Init
  document.addEventListener("DOMContentLoaded", () => {
    wireTriggers();
    let saved: Lang = "en";
    try { saved = (localStorage.getItem(KEY) as Lang) || "en"; } catch {}
    reflectInUI(saved);
    if (saved !== "en") {
      // wait briefly for the Google combo to mount, then apply
      let tries = 0;
      const t = window.setInterval(() => {
        tries += 1;
        if (setComboLanguage(saved) || tries > 20) window.clearInterval(t);
      }, 250);
    }
  });
</script>
