---
import { Image } from "astro:assets";
import logo from "~/assets/aol-logo.png";
import { contact } from "~/data/site";

const nav = [
  { label: "About", href: "#about" },
  { label: "Gurudev", href: "#gurudev" },
  { label: "Activities", href: "#activities" },
  { label: "YLTP", href: "#yltp" },
  { label: "Gallery", href: "#gallery" },
  { label: "Support", href: "#support" },
  { label: "Visit", href: "#contact" },
];
---

<header
  id="site-header"
  data-scrolled="false"
  class="hv-header fixed inset-x-0 top-0 z-50 transition-[background,backdrop-filter,border-color,box-shadow] duration-500 ease-out"
>
  <div class="container-x flex items-center justify-between py-4 md:py-5">
    <a href="#top" class="group flex items-center gap-3" aria-label="Harivan Ashram home">
      <Image
        src={logo}
        alt="The Art of Living"
        class="hv-logo h-10 w-auto md:h-11"
        widths={[160, 320]}
        sizes="160px"
        loading="eager"
        format="webp"
      />
      <span class="hv-wordmark hidden flex-col leading-none sm:flex">
        <span class="font-serif text-[15px] tracking-tight">Harivan Ashram</span>
        <span class="hv-wordmark-sub mt-1 text-[10px] uppercase tracking-[0.18em]">Tricity · North India</span>
      </span>
    </a>

    <nav class="hidden lg:block" aria-label="Primary">
      <ul class="flex items-center gap-7">
        {
          nav.map((n) => (
            <li>
              <a
                href={n.href}
                class="hv-nav-link font-sans text-[13px] font-light tracking-wide transition-colors"
              >
                {n.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`tel:${contact.phoneIntl}`}
        class="hv-call-pill hidden md:inline-flex items-center gap-2 rounded-full px-4 py-2 font-sans text-[12px] tracking-wide backdrop-blur-md transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="h-4 w-4"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.272.527-.734.417-1.173L6.963 3.102A1.125 1.125 0 0 0 5.872 2.25H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
          />
        </svg>
        Call us
      </a>
      <button
        type="button"
        id="mobile-menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="hv-burger lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full backdrop-blur-md transition"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5m-16.5 5.25h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    hidden
    class="lg:hidden border-t border-ink-100/60 bg-cream-50/95 backdrop-blur-xl"
  >
    <ul class="container-x flex flex-col gap-1 py-4">
      {
        nav.map((n) => (
          <li>
            <a
              href={n.href}
              class="block rounded-md px-2 py-2.5 font-sans text-sm tracking-wide text-ink-500 transition hover:bg-cream-200 hover:text-ink-700"
              data-mobile-link
            >
              {n.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2 grid grid-cols-2 gap-2">
        <a
          href={`tel:${contact.phoneIntl}`}
          class="flex items-center justify-center rounded-full border border-ink-100 bg-cream-100 px-3 py-2 text-xs tracking-wide text-ink-600"
        >Call</a>
        <a
          href={`https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(contact.whatsappMessage)}`}
          class="flex items-center justify-center rounded-full bg-sage-700 px-3 py-2 text-xs tracking-wide text-cream-50"
        >WhatsApp</a>
      </li>
    </ul>
  </div>
</header>

<style is:global>
  /* ----- header colour states (no Tailwind group needed) ----- */

  /* over-hero (transparent header): white nav + chrome */
  .hv-header[data-scrolled="false"] {
    background: transparent;
  }
  .hv-header[data-scrolled="false"] .hv-wordmark > span:first-child { color: #ffffff; }
  .hv-header[data-scrolled="false"] .hv-wordmark-sub { color: rgba(255, 255, 255, 0.75); }
  .hv-header[data-scrolled="false"] .hv-nav-link {
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }
  .hv-header[data-scrolled="false"] .hv-nav-link:hover { color: #ffffff; }
  .hv-header[data-scrolled="false"] .hv-call-pill {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  .hv-header[data-scrolled="false"] .hv-call-pill:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 1);
  }
  .hv-header[data-scrolled="false"] .hv-burger {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  /* a true transparent logo on dark = display as-is */

  /* scrolled (cream backdrop): dark nav + chrome */
  .hv-header[data-scrolled="true"] {
    background: rgba(253, 251, 246, 0.92);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(232, 227, 220, 0.7);
    box-shadow: 0 2px 24px -12px rgba(24, 21, 15, 0.18);
  }
  .hv-header[data-scrolled="true"] .hv-wordmark > span:first-child { color: var(--color-ink-700); }
  .hv-header[data-scrolled="true"] .hv-wordmark-sub { color: var(--color-ink-300); }
  .hv-header[data-scrolled="true"] .hv-nav-link { color: var(--color-ink-500); }
  .hv-header[data-scrolled="true"] .hv-nav-link:hover { color: var(--color-ink-700); }
  .hv-header[data-scrolled="true"] .hv-call-pill {
    color: var(--color-ink-600);
    background: rgba(253, 251, 246, 0.7);
    border: 1px solid rgba(232, 227, 220, 0.8);
  }
  .hv-header[data-scrolled="true"] .hv-call-pill:hover {
    color: var(--color-ink-700);
    border-color: var(--color-saffron-300);
  }
  .hv-header[data-scrolled="true"] .hv-burger {
    color: var(--color-ink-600);
    background: rgba(253, 251, 246, 0.7);
    border: 1px solid rgba(232, 227, 220, 0.8);
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const open = menu.hasAttribute("hidden") ? false : true;
      if (open) {
        menu.setAttribute("hidden", "");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Open menu");
      } else {
        menu.removeAttribute("hidden");
        btn.setAttribute("aria-expanded", "true");
        btn.setAttribute("aria-label", "Close menu");
      }
    });
    menu.querySelectorAll<HTMLAnchorElement>("[data-mobile-link]").forEach((a) =>
      a.addEventListener("click", () => {
        menu.setAttribute("hidden", "");
        btn.setAttribute("aria-expanded", "false");
      }),
    );
  }
</script>
