---
import { events } from "~/data/site";
---

<section id="events" class="relative bg-cream-50">
  <div class="container-x py-[var(--section-y)]">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="reveal eyebrow">Event Gallery</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          A year of breath, <span class="h-display-italic">devotion</span> and seva.
        </h2>
      </div>
      <p class="reveal lead max-w-md text-ink-600" style="transition-delay: 120ms">
        From village satsangs to Vedic homas — Harivan has hosted thousands in community
        celebration. A glimpse of what's been unfolding.
      </p>
    </div>

    <div class="mt-10" data-events-carousel>
      <div class="hv-carousel-track-wrap relative overflow-hidden">
        <ul
          class="hv-carousel-track flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-4 md:gap-6 md:overflow-visible md:pb-0"
          data-events-track
        >
          {
            events.map((a) => (
              <li
                class="hv-carousel-card snap-start flex-shrink-0 basis-[85%] sm:basis-[58%] md:basis-[calc((100%-2*1.5rem)/3)] xl:basis-[calc((100%-2*1.5rem)/3)]"
              >
                <article class="group flex h-full flex-col overflow-hidden rounded-2xl bg-cream-100 ring-1 ring-ink-100/70 ring-soft">
                  <div class="relative aspect-[5/4] w-full shrink-0 overflow-hidden sm:aspect-[4/3]">
                    <img
                      src={a.image}
                      alt={a.title}
                      loading="lazy"
                      decoding="async"
                      class="hv-cover-img transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                      onerror="this.style.background='linear-gradient(135deg,#ebe1cd,#b1c0a2)'; this.removeAttribute('src');"
                    />
                  </div>
                  <div class="flex flex-1 flex-col p-6 md:p-7">
                    <h3 class="font-serif text-xl text-ink-700 md:text-2xl">{a.title}</h3>
                    <p class="mt-3 flex-1 body-text text-sm">{a.desc}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Controls -->
      <div class="mt-6 flex items-center justify-between gap-4">
        <div class="flex items-center gap-2" data-events-dots aria-hidden="true">
          {
            events.map((_, i) => (
              <button
                type="button"
                data-events-dot={i}
                aria-label={`Slide ${i + 1}`}
                class={`h-1.5 rounded-full transition-all ${i === 0 ? "w-8 bg-ink-500" : "w-3 bg-ink-200 hover:bg-ink-300"}`}
              />
            ))
          }
        </div>
        <div class="flex items-center gap-2">
          <button
            type="button"
            data-events-prev
            aria-label="Previous"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-ink-100 bg-cream-50 text-ink-600 transition hover:border-ink-200 hover:bg-cream-100"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
          </button>
          <button
            type="button"
            data-events-next
            aria-label="Next"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-ink-100 bg-cream-50 text-ink-600 transition hover:border-ink-200 hover:bg-cream-100"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide native scrollbar inside carousel track */
  .hv-carousel-track { scrollbar-width: none; -ms-overflow-style: none; }
  .hv-carousel-track::-webkit-scrollbar { display: none; }
</style>

<script>
  const root = document.querySelector<HTMLElement>("[data-events-carousel]");
  const track = root?.querySelector<HTMLUListElement>("[data-events-track]");
  if (root && track) {
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-events-dot]"));
    const prev = root.querySelector<HTMLButtonElement>("[data-events-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-events-next]");
    const cards = Array.from(track.querySelectorAll<HTMLLIElement>(".hv-carousel-card"));
    const total = cards.length;

    let active = 0;
    let timer: number | null = null;
    let userInteracting = false;

    const isWide = () => window.matchMedia("(min-width: 768px)").matches;

    const visibleCount = () => (isWide() ? 3 : 1);

    const setActive = (idx: number, smooth = true) => {
      const max = Math.max(0, total - visibleCount());
      active = Math.max(0, Math.min(idx, max));
      const card = cards[active];
      if (!card) return;
      track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: smooth ? "smooth" : "auto" });
      dots.forEach((d, di) => {
        const on = di === active;
        d.classList.toggle("w-8", on);
        d.classList.toggle("bg-ink-500", on);
        d.classList.toggle("w-3", !on);
        d.classList.toggle("bg-ink-200", !on);
      });
    };

    const advance = () => {
      const max = Math.max(0, total - visibleCount());
      const nextIdx = active >= max ? 0 : active + 1;
      setActive(nextIdx);
    };

    const startTimer = () => {
      stopTimer();
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) return;
      timer = window.setInterval(() => {
        if (!userInteracting) advance();
      }, 5000);
    };
    const stopTimer = () => {
      if (timer) { window.clearInterval(timer); timer = null; }
    };

    prev?.addEventListener("click", () => { userInteracting = true; setActive(active - 1); });
    next?.addEventListener("click", () => { userInteracting = true; setActive(active + 1); });
    dots.forEach((d, i) => d.addEventListener("click", () => { userInteracting = true; setActive(i); }));

    // Pause auto-advance on hover; resume on leave
    root.addEventListener("mouseenter", () => { userInteracting = true; });
    root.addEventListener("mouseleave", () => { userInteracting = false; });
    track.addEventListener("touchstart", () => { userInteracting = true; }, { passive: true });
    track.addEventListener("touchend", () => { window.setTimeout(() => (userInteracting = false), 4000); }, { passive: true });

    window.addEventListener("resize", () => setActive(active, false));
    setActive(0, false);
    startTimer();
  }
</script>
