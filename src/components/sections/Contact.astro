---
import Button from "~/components/ui/Button.astro";
import { contact } from "~/data/site";
const wa = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(contact.whatsappMessage)}`;
// z=13 gives nearby context without making the pin feel too tightly cropped.
const mapEmbed = `https://www.google.com/maps?q=${contact.mapsQuery}&z=13&output=embed`;
---

<section id="contact" class="relative bg-cream-50">
  <div class="container-x py-[var(--section-y)]">
    <div class="grid gap-14 md:grid-cols-12 md:gap-20">
      <div class="md:col-span-5">
        <p class="reveal eyebrow">Visit Harivan</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          Come, sit, breathe.
        </h2>
        <p class="reveal lead mt-6 max-w-md" style="transition-delay: 120ms">
          You are warmly welcomed to attend a satsang, walk the land, or simply
          share a chai. Reach out — we'll guide you in.
        </p>

        <div class="reveal mt-10 space-y-6" style="transition-delay: 180ms">
          <div>
            <p class="eyebrow">Address</p>
            <p class="mt-2 body-text text-sm">{contact.addressFull}</p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <p class="eyebrow">Phone</p>
              <a
                href={`tel:${contact.phoneIntl}`}
                class="mt-2 block font-serif text-lg text-ink-700 hover:text-saffron-500"
              >{contact.phone}</a>
            </div>
            <div>
              <p class="eyebrow">Email</p>
              <a
                href={`mailto:${contact.email}`}
                class="mt-2 block whitespace-nowrap font-sans text-[15px] text-ink-700 hover:text-saffron-500 lg:text-base xl:font-serif xl:text-lg"
              >{contact.email}</a>
            </div>
          </div>
        </div>

        <div class="reveal mt-10 flex flex-wrap items-center gap-3" style="transition-delay: 240ms">
          <Button href={`tel:${contact.phoneIntl}`} variant="primary" size="lg">Call</Button>
          <Button href={wa} variant="saffron" size="lg" external>WhatsApp</Button>
        </div>
      </div>

      <div class="md:col-span-7">
        <div class="reveal overflow-hidden rounded-2xl ring-1 ring-ink-100/70 ring-soft" style="transition-delay: 200ms">
          <iframe
            title="Harivan Ashram on Google Maps"
            src={mapEmbed}
            class="aspect-[4/3] w-full md:aspect-[5/4]"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
