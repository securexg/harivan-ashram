---
import { about } from "~/data/site";
---

<section id="about" class="relative bg-cream-50">
  <div class="container-x py-[var(--section-y)]">
    <div class="grid gap-14 md:grid-cols-12 md:gap-20">
      <div class="md:col-span-5">
        <p class="reveal eyebrow">{about.eyebrow}</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl lg:text-[56px]" style="transition-delay: 60ms">
          {about.title}
        </h2>
      </div>
      <div class="md:col-span-7">
        <div class="space-y-6">
          {
            about.body.map((p, i) => (
              <p class="reveal lead" style={`transition-delay: ${120 + i * 60}ms`}>
                {p}
              </p>
            ))
          }
        </div>

        <div class="reveal mt-10 hairline" style="transition-delay: 320ms"></div>

        <div class="mt-10 grid gap-8 sm:grid-cols-3">
          {
            about.pillars.map((p, i) => (
              <div class="reveal" style={`transition-delay: ${360 + i * 80}ms`}>
                <p class="font-serif text-2xl text-ink-700">
                  {String(i + 1).padStart(2, "0")}
                </p>
                <p class="mt-3 font-sans text-[15px] text-ink-700" style="font-weight:400; letter-spacing:0.01em;">
                  {p.title}
                </p>
                <p class="mt-2 body-text text-sm">{p.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
