---
import { about } from "~/data/site";
---

<section id="about" class="relative bg-cream-50">
  <div class="container-x py-[var(--section-y)]">
    <div class="grid gap-12 md:grid-cols-12 md:items-start md:gap-16 lg:gap-20">
      <!-- Formal left column: copy + pillars -->
      <div class="md:col-span-6">
        <p class="reveal eyebrow">{about.eyebrow}</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl lg:text-[56px]" style="transition-delay: 60ms">
          {about.title}
        </h2>

        <div class="mt-8 space-y-6">
          {
            about.body.map((p, i) => (
              <p class="reveal lead text-ink-600" style={`transition-delay: ${100 + i * 60}ms`}>
                {p}
              </p>
            ))
          }
        </div>

        <div class="reveal mt-10 hairline" style="transition-delay: 260ms"></div>

        <div class="mt-10 grid gap-8 sm:grid-cols-3">
          {
            about.pillars.map((p, i) => (
              <div class="reveal" style={`transition-delay: ${300 + i * 80}ms`}>
                <p class="font-serif text-2xl text-ink-700">
                  {String(i + 1).padStart(2, "0")}
                </p>
                <p class="mt-3 font-sans text-[15px] text-ink-700" style="font-weight:400; letter-spacing:0.01em;">
                  {p.title}
                </p>
                <p class="mt-2 body-text text-sm">{p.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right column: a wide event/community moment from the ashram -->
      <div class="md:col-span-6">
        <figure class="reveal overflow-hidden rounded-2xl ring-1 ring-ink-100/70 ring-soft" style="transition-delay: 120ms">
          <div class="relative aspect-[4/5] w-full overflow-hidden lg:aspect-[3/4]">
            <picture class="absolute inset-0 block">
              <source
                type="image/webp"
                srcset="/images/activities/navratri/photo-29-640.webp 640w, /images/activities/navratri/photo-29-1024.webp 1024w, /images/activities/navratri/photo-29-1600.webp 1600w"
                sizes="(min-width: 768px) 45vw, 100vw"
              />
              <img
                src="/images/activities/navratri/photo-29.webp"
                alt="Harivan Ashram — community gathering"
                loading="lazy"
                decoding="async"
                class="hv-cover-img object-center"
              />
            </picture>
          </div>
        </figure>
      </div>
    </div>
  </div>
</section>
