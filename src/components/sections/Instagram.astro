---
/* Lightweight Instagram strip — links to @harivanashram with a small grid of
   stills pulled from the existing photo library (no API key needed). */
import { links } from "~/data/site";

const insta = [
  "/images/activities/navratri/photo-31.webp",
  "/images/activities/navratri/photo-33.webp",
  "/images/activities/navratri/photo-37.webp",
  "/images/activities/navratri/photo-41.webp",
  "/images/activities/navratri/photo-43.webp",
  "/images/activities/shobha-yatra/photo-13.webp",
];
---

<section id="instagram" class="relative bg-cream-50 overflow-hidden">
  <div class="container-x py-[clamp(3rem,6vw,5rem)]">
    <div class="grid items-center gap-10 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-4 animate-slide-left">
        <p class="reveal eyebrow hover-underline inline-block">Follow along</p>
        <h2 class="reveal h-display mt-4 text-3xl text-ink-700 md:text-4xl text-reveal-words" style="transition-delay: 60ms">
          @harivanashram on <span class="h-display-italic">Instagram</span>.
        </h2>
        <p class="reveal lead mt-5 text-ink-600 animate-fade-up" style="transition-delay: 120ms">
          Day-to-day moments, satsang clips and event updates — all in one place.
        </p>
        <a
          href={links.instagram}
          target="_blank"
          rel="noopener"
          class="reveal mt-6 inline-flex items-center gap-2 rounded-full border border-ink-100 bg-cream-100 px-5 py-2.5 text-[12px] font-medium uppercase tracking-[0.16em] text-ink-700 transition hover:border-saffron-300 magnetic-btn btn-press ripple hover-glow"
          style="transition-delay: 180ms"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
            <path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.9.2 2.4.4.6.2 1.1.5 1.5.9.4.4.7.9.9 1.5.2.5.4 1.2.4 2.4 0 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.9-.4 2.4-.2.6-.5 1.1-.9 1.5-.4.4-.9.7-1.5.9-.5.2-1.2.4-2.4.4-1.2 0-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.9-.2-2.4-.4-.6-.2-1.1-.5-1.5-.9-.4-.4-.7-.9-.9-1.5-.2-.5-.4-1.2-.4-2.4 0-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c0-1.2.2-1.9.4-2.4.2-.6.5-1.1.9-1.5.4-.4.9-.7 1.5-.9.5-.2 1.2-.4 2.4-.4 1.2-.1 1.6-.1 4.8-.1zm0 1.8c-3.1 0-3.5 0-4.7.1-.9 0-1.4.2-1.7.3-.4.2-.7.4-1 .7-.3.3-.5.6-.7 1-.1.3-.3.8-.3 1.7-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 .9.2 1.4.3 1.7.2.4.4.7.7 1 .3.3.6.5 1 .7.3.1.8.3 1.7.3 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c.9 0 1.4-.2 1.7-.3.4-.2.7-.4 1-.7.3-.3.5-.6.7-1 .1-.3.3-.8.3-1.7.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-.9-.2-1.4-.3-1.7-.2-.4-.4-.7-.7-1-.3-.3-.6-.5-1-.7-.3-.1-.8-.3-1.7-.3-1.2-.1-1.6-.1-4.7-.1zm0 3.1a4.9 4.9 0 1 1 0 9.8 4.9 4.9 0 0 1 0-9.8zm0 1.8a3.1 3.1 0 1 0 0 6.2 3.1 3.1 0 0 0 0-6.2zm5.1-2.2a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2z" />
          </svg>
          Open Instagram
        </a>
      </div>

      <div class="md:col-span-8 animate-slide-right">
        <a
          href={links.instagram}
          target="_blank"
          rel="noopener"
          aria-label="Open @harivanashram on Instagram"
          class="block"
        >
          <div class="reveal grid grid-cols-3 gap-1.5 sm:gap-2 md:grid-cols-6 md:gap-2.5 animate-stagger" style="transition-delay: 100ms">
            {
              insta.map((src) => (
                <figure class="relative aspect-square overflow-hidden rounded-md bg-cream-200 img-zoom card-lift animate-scale">
                  <img
                    src={src}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="hv-cover-img transition-transform duration-700 ease-out group-hover:scale-[1.08]"
                  />
                </figure>
              ))
            }
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
