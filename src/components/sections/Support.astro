---
import Button from "~/components/ui/Button.astro";
import { contact, support } from "~/data/site";
const wa = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
  "Hari Om. I'd like to contribute towards Harivan Ashram. Please share how I can help.",
)}`;
---

<section id="support" class="relative bg-cream-100">
  <div class="container-x py-[var(--section-y)]">
    <div class="grid gap-12 md:grid-cols-12 md:gap-16 md:items-center">
      <div class="md:col-span-5">
        <p class="reveal eyebrow">{support.eyebrow}</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          {support.title}
        </h2>
        <p class="reveal lead mt-6 text-ink-600" style="transition-delay: 120ms">{support.body}</p>

        <div class="reveal mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap" style="transition-delay: 180ms">
          <Button href={`tel:${contact.phoneIntl}`} variant="primary" size="lg" class="w-full justify-center sm:w-auto">
            Call us
          </Button>
          <Button href={wa} variant="ghost" size="lg" external class="w-full justify-center border border-ink-200 bg-cream-50 sm:w-auto">
            WhatsApp
          </Button>
        </div>
      </div>

      <div class="md:col-span-7">
        <figure
          class="reveal overflow-hidden rounded-2xl ring-1 ring-ink-100/70 ring-soft"
          style="transition-delay: 140ms"
        >
          <div class="relative aspect-[16/10] w-full overflow-hidden md:aspect-[16/11]">
            <picture class="absolute inset-0 block">
              <source
                type="image/webp"
                srcset="/images/activities/navratri/photo-25-640.webp 640w, /images/activities/navratri/photo-25-1024.webp 1024w, /images/activities/navratri/photo-25-1600.webp 1600w"
                sizes="(min-width: 768px) 55vw, 100vw"
              />
              <img
                src="/images/activities/navratri/photo-25.webp"
                alt="Harivan Ashram grounds"
                loading="lazy"
                decoding="async"
                class="hv-cover-img"
              />
            </picture>
          </div>
        </figure>
      </div>
    </div>
  </div>
</section>
