---
import Button from "~/components/ui/Button.astro";
import { contact, support } from "~/data/site";
const wa = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
  "Hari Om. I'd like to contribute towards Harivan Ashram. Please share the bank/UPI details.",
)}`;
---

<section id="support" class="relative bg-cream-100">
  <div class="container-x py-[var(--section-y)]">
    <div class="grid gap-14 md:grid-cols-12 md:gap-20">
      <div class="md:col-span-5">
        <p class="reveal eyebrow">{support.eyebrow}</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          {support.title}
        </h2>
        <p class="reveal lead mt-6" style="transition-delay: 120ms">{support.body}</p>
      </div>

      <div class="md:col-span-7">
        <div class="reveal grid grid-cols-2 gap-3 sm:grid-cols-4" style="transition-delay: 160ms">
          {
            support.tiers.map((t) => (
              <div class="rounded-2xl border border-ink-100 bg-cream-50 p-5 text-center ring-soft">
                <p class="font-serif text-2xl text-ink-700 md:text-3xl">{t.amount}</p>
                <p class="mt-1 text-[11px] tracking-[0.18em] uppercase text-ink-300">{t.note}</p>
              </div>
            ))
          }
        </div>

        <div
          class="reveal mt-8 rounded-2xl border border-saffron-200 bg-saffron-100/50 p-7 md:p-9"
          style="transition-delay: 220ms"
        >
          <p class="eyebrow text-saffron-500">Contribute today</p>
          <p class="lead mt-3 text-ink-600">{support.bankPlaceholder}</p>
          <p class="mt-3 text-xs italic text-ink-300">{support.signatories}</p>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <Button href={`tel:${contact.phoneIntl}`} variant="primary" size="lg">Call for details</Button>
            <Button href={wa} variant="ghost" size="lg" external>WhatsApp us</Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
