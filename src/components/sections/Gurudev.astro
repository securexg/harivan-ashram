---
import { gurudev, links } from "~/data/site";
---

<section id="gurudev" class="relative bg-cream-100">
  <div class="container-x py-[var(--section-y)]">
    <div class="grid gap-14 md:grid-cols-12 md:gap-20">
      <div class="md:col-span-5">
        <p class="reveal eyebrow">{gurudev.eyebrow}</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl lg:text-[56px]" style="transition-delay: 60ms">
          {gurudev.title}
        </h2>

        <!-- Gurudev portrait — drop a square/portrait WebP at /public/images/gurudev/portrait.webp to swap. -->
        <figure class="reveal mt-8 overflow-hidden rounded-2xl ring-1 ring-ink-100/70 ring-soft" style="transition-delay: 90ms">
          <img
            src="/images/gurudev/portrait.webp"
            alt="Gurudev Sri Sri Ravi Shankar ji"
            loading="lazy"
            decoding="async"
            class="aspect-[4/5] w-full object-cover object-center"
            onerror="this.style.display='none'; this.parentElement.style.display='none';"
          />
        </figure>

        <p class="reveal lead mt-6" style="transition-delay: 120ms">{gurudev.body}</p>

        <a
          href={links.gurudev}
          target="_blank"
          rel="noopener"
          class="reveal mt-7 inline-flex items-center gap-2 text-[12px] tracking-[0.18em] uppercase text-saffron-500 hover:text-saffron-400 transition-colors"
          style="transition-delay: 180ms"
        >
          Visit gurudev.artofliving.org
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="md:col-span-7">
        <figure class="reveal relative" style="transition-delay: 200ms">
          <span class="absolute -left-2 -top-3 font-serif text-[120px] leading-none text-saffron-200 md:-left-4 md:-top-6 md:text-[160px]" aria-hidden="true">“</span>
          <blockquote class="relative pl-8 md:pl-12">
            <p class="h-display-italic text-2xl text-ink-700 md:text-3xl lg:text-[34px]">
              {gurudev.quote}
            </p>
            <figcaption class="mt-6 text-sm text-ink-300 tracking-wide">
              {gurudev.attribution}
            </figcaption>
          </blockquote>
        </figure>

        <div class="reveal mt-12 rounded-2xl border border-ink-100/80 bg-cream-50 p-7 md:p-10" style="transition-delay: 280ms">
          <p class="eyebrow">About The Art of Living</p>
          <p class="lead mt-4">{gurudev.aolBlurb}</p>
          <a
            href={links.artOfLiving}
            target="_blank"
            rel="noopener"
            class="mt-5 inline-flex items-center gap-2 text-[12px] tracking-[0.18em] uppercase text-saffron-500 hover:text-saffron-400 transition-colors"
          >
            Visit artofliving.org
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
