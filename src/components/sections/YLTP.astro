---
import Button from "~/components/ui/Button.astro";
import { contact, yltp } from "~/data/site";
const wa = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
  "Hari Om. I'd like to register for YLTP (23-29 May 2026) at Harivan Ashram.",
)}`;
---

<section
  id="yltp"
  class="relative overflow-hidden bg-ink-700 text-cream-50"
>
  <!-- Subtle textural background -->
  <div class="pointer-events-none absolute inset-0 -z-0 opacity-[0.18]" aria-hidden="true">
    <div class="absolute -left-32 top-1/4 h-[480px] w-[480px] rounded-full bg-saffron-400 blur-[140px]"></div>
    <div class="absolute -right-32 bottom-0 h-[420px] w-[420px] rounded-full bg-sage-700 blur-[160px]"></div>
  </div>

  <div class="container-x relative z-10 grid gap-14 py-[var(--section-y)] md:grid-cols-12 md:gap-20">
    <div class="md:col-span-7">
      <p class="reveal eyebrow text-cream-200/90">Upcoming · Residential</p>
      <h2 class="reveal h-display mt-5 text-4xl md:text-5xl lg:text-[64px]" style="transition-delay: 60ms">
        {yltp.title}
      </h2>
      <p class="reveal lead mt-6 max-w-xl text-cream-200" style="transition-delay: 120ms">
        {yltp.copy}
      </p>

      <dl class="reveal mt-10 grid grid-cols-2 gap-6 sm:grid-cols-4" style="transition-delay: 180ms">
        {
          [
            { label: "Dates", value: yltp.date },
            { label: "Duration", value: yltp.duration },
            { label: "Age group", value: yltp.age },
            { label: "Contribution", value: yltp.donation },
          ].map((item) => (
            <div>
              <dt class="text-[10px] tracking-[0.2em] uppercase text-cream-200/70">{item.label}</dt>
              <dd class="mt-2 font-serif text-lg text-cream-50">{item.value}</dd>
            </div>
          ))
        }
      </dl>

      <p class="reveal mt-8 text-sm text-cream-200/70" style="transition-delay: 220ms">
        {yltp.facilitators}
      </p>

      <div class="reveal mt-10 flex flex-wrap items-center gap-3" style="transition-delay: 280ms">
        <Button href={`tel:${contact.phoneIntl}`} variant="saffron" size="lg">Call to register</Button>
        <Button href={wa} variant="outline" size="lg" external class="text-cream-50 border-cream-200/30 hover:bg-cream-50/10">
          Register via WhatsApp
        </Button>
      </div>
    </div>

    <div class="md:col-span-5">
      <div class="reveal relative mx-auto w-full max-w-[300px]" style="transition-delay: 200ms">
        <div class="relative aspect-[9/16] overflow-hidden rounded-[36px] border-[10px] border-ink-600 bg-ink-600 shadow-[0_60px_120px_-40px_rgba(0,0,0,0.6)]">
          <video
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/videos/yltp/posters/yltp-teaser.webp"
            class="h-full w-full object-cover"
          >
            <source src="/videos/yltp/yltp-teaser.mp4" type="video/mp4" />
          </video>
          <span class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-cream-50/10 rounded-[28px]"></span>
        </div>
        <p class="mt-4 text-center text-[11px] tracking-[0.18em] uppercase text-cream-200/70">
          YLTP at Harivan · with Gurudev ji
        </p>
      </div>
    </div>
  </div>
</section>
