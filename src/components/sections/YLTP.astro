---
import Button from "~/components/ui/Button.astro";
import { contact, yltp } from "~/data/site";
const wa = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
  "Hari Om. I'd like to register for YLTP (23-29 May 2026) at Harivan Ashram.",
)}`;
---

<section
  id="yltp"
  class="relative overflow-hidden bg-ink-700 text-cream-50"
>
  <div class="pointer-events-none absolute inset-0 -z-0 opacity-[0.18]" aria-hidden="true">
    <div class="absolute -left-32 top-1/4 h-[480px] w-[480px] rounded-full bg-saffron-400 blur-[140px]"></div>
    <div class="absolute -right-32 bottom-0 h-[420px] w-[420px] rounded-full bg-sage-700 blur-[160px]"></div>
  </div>

  <div class="container-x relative z-10 grid gap-14 py-[var(--section-y)] md:grid-cols-12 md:gap-20">
    <div class="md:col-span-7">
      <p class="reveal font-sans text-xs uppercase tracking-[0.22em] text-cream-100">Upcoming · Residential</p>
      <h2 class="reveal h-display mt-5 text-4xl text-cream-50 md:text-5xl lg:text-[64px]" style="transition-delay: 60ms">
        {yltp.title}
      </h2>
      <p
        class="reveal mt-6 max-w-xl font-sans text-base font-normal leading-relaxed text-cream-100 md:text-lg"
        style="transition-delay: 120ms"
      >
        {yltp.copy}
      </p>

      <dl class="reveal mt-10 grid grid-cols-2 gap-6 sm:grid-cols-4" style="transition-delay: 180ms">
        {
          [
            { label: "Dates", value: yltp.date },
            { label: "Duration", value: yltp.duration },
            { label: "Age group", value: yltp.age },
            { label: "Contribution", value: yltp.donation },
          ].map((item) => (
            <div>
              <dt class="font-sans text-[10px] uppercase tracking-[0.2em] text-cream-100/90">{item.label}</dt>
              <dd class="mt-2 font-serif text-lg text-cream-50">{item.value}</dd>
            </div>
          ))
        }
      </dl>

      <p class="reveal mt-8 font-sans text-sm text-cream-100/95" style="transition-delay: 220ms">
        {yltp.facilitators}
      </p>

      <div class="reveal mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap" style="transition-delay: 280ms">
        <Button href={`tel:${contact.phoneIntl}`} variant="saffron" size="lg" class="w-full justify-center sm:w-auto">
          Call to register
        </Button>
        <Button
          href={wa}
          variant="outlineLight"
          size="lg"
          external
          class="w-full justify-center sm:w-auto"
        >
          Register via WhatsApp
        </Button>
      </div>
    </div>

    <div class="md:col-span-5">
      <div class="reveal relative mx-auto w-full max-w-[300px]" style="transition-delay: 200ms" data-yltp-frame>
        <div class="relative aspect-[9/16] overflow-hidden rounded-[36px] border-[10px] border-ink-600 bg-ink-600 shadow-[0_60px_120px_-40px_rgba(0,0,0,0.6)]">
          <video
            data-yltp-video
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/videos/yltp/posters/yltp-teaser.webp"
            class="absolute inset-0 h-full w-full hv-cover-img"
          >
            <source src="/videos/yltp/yltp-teaser.mp4" type="video/mp4" />
          </video>
          <span class="pointer-events-none absolute inset-0 rounded-[28px] ring-1 ring-inset ring-cream-50/10"></span>

          <button
            type="button"
            data-yltp-mute
            aria-label="Unmute video"
            aria-pressed="true"
            class="absolute bottom-4 right-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-ink-700/55 text-cream-50 backdrop-blur-md transition hover:bg-ink-700/80"
          >
            <svg data-icon-muted xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6 4.72-4.72a.75.75 0 0 1 1.28.531V19.94a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.506-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.395C2.806 8.757 3.63 8.25 4.51 8.25H6.75Z" />
            </svg>
            <svg data-icon-unmuted xmlns="http://www.w3.org/2000/svg" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.506-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.395C2.806 8.757 3.63 8.25 4.51 8.25H6.75Z" />
            </svg>
          </button>
        </div>
        <p class="mt-4 text-center font-sans text-[11px] uppercase tracking-[0.18em] text-cream-100/85">
          A glimpse of YLTP at Harivan
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const frame = document.querySelector<HTMLDivElement>("[data-yltp-frame]");
    const video = frame?.querySelector<HTMLVideoElement>("[data-yltp-video]");
    const btn = frame?.querySelector<HTMLButtonElement>("[data-yltp-mute]");
    if (!video || !btn) return;

    const syncIcons = () => {
      const muted = video.muted;
      const mutedIcon = btn.querySelector<SVGElement>("[data-icon-muted]");
      const unmutedIcon = btn.querySelector<SVGElement>("[data-icon-unmuted]");
      if (mutedIcon && unmutedIcon) {
        mutedIcon.classList.toggle("hidden", !muted);
        unmutedIcon.classList.toggle("hidden", muted);
      }
      btn.setAttribute("aria-pressed", muted ? "true" : "false");
      btn.setAttribute("aria-label", muted ? "Unmute video" : "Mute video");
    };

    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      const willUnmute = video.muted;
      if (willUnmute) {
        // Safari/iOS need ALL of: property false, attribute removed, volume set,
        // and play() called synchronously inside the click gesture.
        video.muted = false;
        video.removeAttribute("muted");
        video.volume = 1;
        syncIcons();
        try {
          await video.play();
        } catch {
          // Autoplay-with-sound was blocked — revert silently
          video.muted = true;
          syncIcons();
        }
      } else {
        video.muted = true;
        syncIcons();
      }
    });
    syncIcons();
  });
</script>
