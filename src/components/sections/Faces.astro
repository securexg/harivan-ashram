---
/* Faces of Harivan — always-moving marquee of smiling portraits.
   No pause-on-hover; respects prefers-reduced-motion (slower, not stopped). */

const happyFaces = [
  "photo-36.webp",
  "photo-11.webp",
  "photo-43.webp",
  "photo-05.webp",
  "photo-39.webp",
  "photo-13.webp",
  "photo-32.webp",
  "photo-08.webp",
  "photo-45.webp",
  "photo-17.webp",
  "photo-41.webp",
  "photo-03.webp",
  "photo-30-640.webp",
  "photo-44.webp",
  "photo-10.webp",
  "photo-38.webp",
  "photo-12.webp",
  "photo-42-2400.webp",
  "photo-28.webp",
  "photo-09.webp",
  "photo-33.webp",
];

const faces = happyFaces.map((file) => ({ src: `/images/happy-faces/${file}`, alt: "Smiling moments at Harivan" }));
const loop = [...faces, ...faces];
---

<section id="faces" class="relative overflow-hidden bg-cream-100">
  <div class="container-x py-[var(--section-y)]">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="reveal eyebrow">Happy faces</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          Volunteers, devotees, <span class="h-display-italic">friends</span>.
        </h2>
      </div>
      <p class="reveal max-w-md text-sm text-ink-500" style="transition-delay: 120ms">
        The real ashram is its people — bright moments from gatherings, yatras and seva at Harivan.
      </p>
    </div>
  </div>

  <div class="relative">
    <span class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-cream-100 to-transparent md:w-32" aria-hidden="true"></span>
    <span class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-cream-100 to-transparent md:w-32" aria-hidden="true"></span>

    <div class="hv-marquee flex gap-4 pb-[var(--section-y)] pt-2 md:gap-6">
      <ul class="hv-marquee-track flex shrink-0 items-stretch gap-4 md:gap-6">
        {
          loop.map((f, i) => (
            <li class="block w-[180px] shrink-0 sm:w-[220px] md:w-[260px] lg:w-[300px]">
              <figure class="overflow-hidden rounded-2xl bg-cream-50 ring-1 ring-ink-100/70 ring-soft">
                <div class="relative aspect-[3/4] w-full overflow-hidden">
                  <img
                    src={f.src}
                    alt={i < faces.length ? f.alt : ""}
                    loading="lazy"
                    decoding="async"
                    class="hv-cover-img object-[center_22%]"
                  />
                </div>
              </figure>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
