---
/** Gallery — compact grid, max three columns. */

interface GalleryItem { src: string; alt: string }

// Curated mix — none of these are reused in Hero / About / Gurudev / Events / Insta strip.
const gallery: GalleryItem[] = [
  { src: "/images/activities/shobha-yatra/photo-02.webp", alt: "Shobha Yatra walk" },
  { src: "/images/activities/navratri/photo-30.webp", alt: "Sacred havan" },
  { src: "/images/activities/shobha-yatra/photo-15.webp", alt: "Somnath group gathering" },
  { src: "/images/activities/navratri/photo-04.webp", alt: "Devotion in song" },
  { src: "/images/activities/navratri/photo-08.webp", alt: "Meditation" },
  { src: "/images/activities/shobha-yatra/photo-13.webp", alt: "Harivan community" },
  { src: "/images/activities/navratri/photo-10.webp", alt: "Aarti" },
  { src: "/images/activities/shobha-yatra/photo-10.webp", alt: "Ashram grounds" },
  { src: "/images/activities/navratri/photo-21.webp", alt: "Friends together" },
];
---

<section id="gallery" class="relative bg-cream-50">
  <div class="container-x pt-[var(--section-y)] pb-12">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="reveal eyebrow">Gallery</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          A walk through <span class="h-display-italic">Harivan</span>.
        </h2>
      </div>
    </div>
  </div>

  <!-- Balanced grid with a filled final row -->
  <div class="container-x pb-[var(--section-y)]">
  <div class="hv-masonry" data-lightbox-grid>
    {
      gallery.map((g) => (
        <button
          type="button"
          data-lightbox-item
          data-src={g.src}
          data-alt={g.alt}
          class="hv-masonry-item group relative block w-full overflow-hidden"
          aria-label={`View ${g.alt}`}
        >
          <img
            src={g.src}
            alt={g.alt}
            loading="lazy"
            decoding="async"
            class="block h-full w-full rounded-lg object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
            onerror="this.style.opacity='0.35'; this.style.background='linear-gradient(135deg,#ebe1cd,#b1c0a2)';"
          />
        </button>
      ))
    }
  </div>
  </div>
</section>

<!-- Lightbox -->
<dialog id="lightbox" class="m-0 h-screen w-screen max-h-screen max-w-none bg-ink-700/95 p-0 text-cream-50 backdrop:bg-ink-700/95">
  <button
    type="button"
    data-lightbox-close
    class="absolute right-5 top-5 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full border border-cream-200/30 bg-ink-700/60 backdrop-blur-md transition hover:bg-ink-700/80"
    aria-label="Close"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
    </svg>
  </button>
  <div class="flex h-full w-full items-center justify-center p-4 md:p-12">
    <img id="lightbox-img" src="" alt="" class="max-h-full max-w-full rounded-lg object-contain" />
  </div>
</dialog>

<style>
  .hv-masonry {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  @media (min-width: 640px)  { .hv-masonry { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; } }
  @media (min-width: 1024px) { .hv-masonry { gap: 16px; } }

  .hv-masonry-item {
    aspect-ratio: 4 / 3;
    padding: 0;
    line-height: 0;
  }
  .hv-masonry-item img { display: block; }
</style>

<script>
  const grid = document.querySelector<HTMLDivElement>("[data-lightbox-grid]");
  const dialog = document.getElementById("lightbox") as HTMLDialogElement | null;
  const img = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const closeBtn = dialog?.querySelector("[data-lightbox-close]") as HTMLButtonElement | null;

  if (grid && dialog && img) {
    grid.querySelectorAll<HTMLButtonElement>("[data-lightbox-item]").forEach((btn) => {
      btn.addEventListener("click", () => {
        img.src = btn.dataset.src ?? "";
        img.alt = btn.dataset.alt ?? "";
        if (typeof dialog.showModal === "function") dialog.showModal();
        else dialog.setAttribute("open", "");
      });
    });
    closeBtn?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => { if (e.target === dialog) dialog.close(); });
  }
</script>
