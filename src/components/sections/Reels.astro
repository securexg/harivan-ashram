---
/** 4 short reels — 2x2 mobile, 1×4 row on laptop, autoplay muted, lazy-load,
   with an unmute toggle on each clip. We serve only MP4/AAC for maximum
   browser compatibility (Safari + iOS); WebM/Opus has spotty support. */
const reels = [
  { mp4: "/videos/reels/reel-1.mp4", poster: "/videos/reels/posters/reel-1.webp" },
  { mp4: "/videos/reels/reel-2.mp4", poster: "/videos/reels/posters/reel-2.webp" },
  { mp4: "/videos/reels/reel-3.mp4", poster: "/videos/reels/posters/reel-3.webp" },
  { mp4: "/videos/reels/reel-4.mp4", poster: "/videos/reels/posters/reel-4.webp" },
];
---

<section id="reels" class="relative bg-cream-100 overflow-hidden">
  <div class="container-x py-[var(--section-y)]">
    <div class="flex flex-wrap items-end justify-between gap-6 animate-fade-up">
      <div class="max-w-xl">
        <p class="reveal eyebrow hover-underline inline-block">Glimpses · Reels</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl text-reveal-words" style="transition-delay: 60ms">
          Moments from the <span class="h-display-italic">ashram</span>.
        </h2>
      </div>
      <p class="reveal text-xs uppercase tracking-[0.18em] text-ink-400 animate-fade-up" style="transition-delay: 120ms">
        Tap a clip to unmute · plays as you scroll
      </p>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-4 md:gap-5 lg:gap-6" data-reels-grid data-reels-track>
      {
        reels.map((r, i) => (
          <figure
            class="reveal group relative overflow-hidden rounded-2xl bg-ink-700/5 ring-1 ring-ink-100/70 ring-soft card-lift hover-glow img-zoom animate-scale"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="relative aspect-[9/16] w-full overflow-hidden">
              <video
                data-reel
                muted
                loop
                playsinline
                preload="none"
                poster={r.poster}
                src={r.mp4}
                class="absolute inset-0 h-full w-full object-cover"
              />
              <span
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-700/35 via-transparent to-transparent transition-opacity duration-500 group-hover:opacity-0"
                aria-hidden="true"
              />

              <button
                type="button"
                data-mute-toggle
                aria-label="Unmute video"
                aria-pressed="true"
                class="absolute bottom-3 right-3 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full bg-ink-700/70 text-cream-50 backdrop-blur-md transition-colors hover:bg-ink-700/90"
              >
                <svg data-icon-muted xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6 4.72-4.72a.75.75 0 0 1 1.28.531V19.94a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.506-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.395C2.806 8.757 3.63 8.25 4.51 8.25H6.75Z" />
                </svg>
                <svg data-icon-unmuted xmlns="http://www.w3.org/2000/svg" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.506-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.395C2.806 8.757 3.63 8.25 4.51 8.25H6.75Z" />
                </svg>
              </button>
            </div>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const grid = document.querySelector<HTMLDivElement>("[data-reels-grid]");
    if (!grid) return;

    const figures = Array.from(grid.querySelectorAll<HTMLElement>("figure"));

    const setIcon = (btn: HTMLButtonElement, muted: boolean) => {
      const m = btn.querySelector<SVGElement>("[data-icon-muted]");
      const u = btn.querySelector<SVGElement>("[data-icon-unmuted]");
      if (m && u) {
        m.classList.toggle("hidden", !muted);
        u.classList.toggle("hidden", muted);
      }
      btn.setAttribute("aria-pressed", muted ? "true" : "false");
      btn.setAttribute("aria-label", muted ? "Unmute video" : "Mute video");
    };

    figures.forEach((figure) => {
      const video = figure.querySelector<HTMLVideoElement>("video[data-reel]");
      const btn = figure.querySelector<HTMLButtonElement>("[data-mute-toggle]");
      if (!video || !btn) return;

      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const willUnmute = video.muted;

        if (willUnmute) {
          // Mute every other reel so we don't get a chorus
          grid.querySelectorAll<HTMLVideoElement>("video[data-reel]").forEach((v) => {
            if (v !== video) {
              v.muted = true;
              const otherBtn = v.closest("figure")?.querySelector<HTMLButtonElement>("[data-mute-toggle]");
              if (otherBtn) setIcon(otherBtn, true);
            }
          });
          // iOS Safari needs muted=false synchronously inside the click, plus a play() call
          video.muted = false;
          video.removeAttribute("muted");
          video.volume = 1;
          setIcon(btn, false);
          try {
            await video.play();
          } catch {
            // Autoplay-with-sound was blocked — revert to muted state silently
            video.muted = true;
            setIcon(btn, true);
          }
        } else {
          video.muted = true;
          setIcon(btn, true);
        }
      });
    });

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const v = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              v.play().catch(() => {});
            } else {
              v.pause();
            }
          }
        },
        { threshold: 0.4 },
      );
      grid.querySelectorAll<HTMLVideoElement>("video[data-reel]").forEach((v) => io.observe(v));
    } else {
      grid.querySelectorAll<HTMLVideoElement>("video[data-reel]").forEach((v) => v.play().catch(() => {}));
    }
  });
</script>
