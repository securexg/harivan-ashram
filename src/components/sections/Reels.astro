---
/** 4 short reels — 2x2 mobile, 1×4 row on laptop, autoplay muted, lazy-load,
   with an unmute toggle in the corner of each clip. */
const reels = [
  { mp4: "/videos/reels/reel-1.mp4", webm: "/videos/reels/reel-1.webm", poster: "/videos/reels/posters/reel-1.webp" },
  { mp4: "/videos/reels/reel-2.mp4", webm: "/videos/reels/reel-2.webm", poster: "/videos/reels/posters/reel-2.webp" },
  { mp4: "/videos/reels/reel-3.mp4", webm: "/videos/reels/reel-3.webm", poster: "/videos/reels/posters/reel-3.webp" },
  { mp4: "/videos/reels/reel-4.mp4", webm: "/videos/reels/reel-4.webm", poster: "/videos/reels/posters/reel-4.webp" },
];
---

<section id="reels" class="relative bg-cream-100">
  <div class="container-x py-[var(--section-y)]">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="reveal eyebrow">Glimpses · Reels</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          Moments from the <span class="h-display-italic">ashram</span>.
        </h2>
      </div>
      <p class="reveal text-xs tracking-[0.18em] uppercase text-ink-300" style="transition-delay: 120ms">
        Tap a clip to unmute · plays as you scroll
      </p>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-4 md:gap-5 lg:gap-6" data-reels-grid>
      {
        reels.map((r, i) => (
          <figure
            class="reveal group relative overflow-hidden rounded-2xl bg-ink-700/5 ring-1 ring-ink-100/70 ring-soft"
            style={`transition-delay: ${i * 60}ms`}
          >
            <div class="relative aspect-[9/16] w-full overflow-hidden">
              <video
                data-reel
                muted
                loop
                playsinline
                preload="none"
                poster={r.poster}
                class="absolute inset-0 h-full w-full object-cover"
              >
                <source data-src-webm={r.webm} type="video/webm" />
                <source data-src-mp4={r.mp4} type="video/mp4" />
              </video>
              <span
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-700/35 via-transparent to-transparent transition-opacity duration-500 group-hover:opacity-0"
                aria-hidden="true"
              />
              <span
                class="absolute right-3 top-3 inline-flex items-center gap-1.5 rounded-full bg-ink-700/55 px-2.5 py-1 text-[10px] tracking-[0.16em] uppercase text-cream-50 backdrop-blur-md"
              >
                <span class="h-1.5 w-1.5 rounded-full bg-saffron-300" /> Live
              </span>

              <button
                type="button"
                data-mute-toggle
                aria-label="Unmute video"
                aria-pressed="true"
                class="absolute bottom-3 right-3 inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink-700/55 text-cream-50 backdrop-blur-md transition hover:bg-ink-700/80"
              >
                <svg data-icon-muted xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6 4.72-4.72a.75.75 0 0 1 1.28.531V19.94a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.506-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.395C2.806 8.757 3.63 8.25 4.51 8.25H6.75Z" />
                </svg>
                <svg data-icon-unmuted xmlns="http://www.w3.org/2000/svg" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.506-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.395C2.806 8.757 3.63 8.25 4.51 8.25H6.75Z" />
                </svg>
              </button>
            </div>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<script>
  const grid = document.querySelector<HTMLDivElement>("[data-reels-grid]");
  if (grid) {
    const figures = grid.querySelectorAll<HTMLElement>("figure");

    const hydrate = (video: HTMLVideoElement) => {
      if (video.dataset.hydrated === "true") return;
      const sources = video.querySelectorAll("source");
      sources.forEach((s) => {
        const webm = s.getAttribute("data-src-webm");
        const mp4 = s.getAttribute("data-src-mp4");
        if (webm) s.setAttribute("src", webm);
        if (mp4) s.setAttribute("src", mp4);
      });
      video.load();
      video.dataset.hydrated = "true";
    };

    const setMute = (video: HTMLVideoElement, btn: HTMLButtonElement, muted: boolean) => {
      video.muted = muted;
      const mutedIcon = btn.querySelector<SVGElement>("[data-icon-muted]");
      const unmutedIcon = btn.querySelector<SVGElement>("[data-icon-unmuted]");
      if (mutedIcon && unmutedIcon) {
        mutedIcon.classList.toggle("hidden", !muted);
        unmutedIcon.classList.toggle("hidden", muted);
      }
      btn.setAttribute("aria-pressed", muted ? "true" : "false");
      btn.setAttribute("aria-label", muted ? "Unmute video" : "Mute video");
    };

    figures.forEach((figure) => {
      const video = figure.querySelector<HTMLVideoElement>("video[data-reel]");
      const btn = figure.querySelector<HTMLButtonElement>("[data-mute-toggle]");
      if (!video || !btn) return;

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        // When user unmutes one, mute all the others to avoid a chorus
        const willUnmute = video.muted;
        if (willUnmute) {
          grid.querySelectorAll<HTMLVideoElement>("video[data-reel]").forEach((v) => {
            if (v !== video) {
              v.muted = true;
              const otherFig = v.closest("figure");
              const otherBtn = otherFig?.querySelector<HTMLButtonElement>("[data-mute-toggle]");
              if (otherBtn) setMute(v, otherBtn, true);
            }
          });
        }
        setMute(video, btn, !willUnmute);
        if (willUnmute) {
          // Some browsers require a fresh play call when audio enables
          video.play().catch(() => {});
        }
      });
    });

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              hydrate(video);
              const playPromise = video.play();
              if (playPromise) playPromise.catch(() => {});
            } else {
              video.pause();
            }
          }
        },
        { threshold: 0.35 },
      );
      grid.querySelectorAll<HTMLVideoElement>("video[data-reel]").forEach((v) => io.observe(v));
    } else {
      grid.querySelectorAll<HTMLVideoElement>("video[data-reel]").forEach((v) => {
        hydrate(v);
        v.play().catch(() => {});
      });
    }
  }
</script>
