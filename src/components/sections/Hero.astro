---
import Button from "~/components/ui/Button.astro";
import { contact, site, yltp } from "~/data/site";
const wa = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(contact.whatsappMessage)}`;

/* Hero slideshow — 7 vibrant moments of celebration, devotion and community.
   Each slug must exist under public/images/<folder>/<slug>-{640,1024,1600,2400}.webp */
const slides: { folder: string; slug: string; alt: string; focal?: string }[] = [
  { folder: "activities/navratri", slug: "photo-30", alt: "Navratri homa at Harivan", focal: "center" },
  { folder: "activities/navratri", slug: "photo-22", alt: "Devotees in celebration" },
  { folder: "activities/shobha-yatra", slug: "photo-09", alt: "Somnath Shobha Yatra procession" },
  { folder: "happy-faces", slug: "photo-44", alt: "Smiling community at Harivan", focal: "center 30%" },
  { folder: "activities/navratri", slug: "photo-35", alt: "Sacred fire ceremony" },
  { folder: "activities/shobha-yatra", slug: "photo-12", alt: "Procession at Harivan" },
  { folder: "happy-faces", slug: "photo-13", alt: "Joyful faces at Harivan" },
];

/** Helper: many happy-faces files don't have responsive variants — render
 *  with a smart srcset where available, plain src otherwise. */
const slideUrl = (folder: string, slug: string, w?: number) => {
  if (folder === "happy-faces") return `/images/happy-faces/${slug}.webp`;
  if (!w) return `/images/${folder}/${slug}.webp`;
  return `/images/${folder}/${slug}-${w}.webp`;
};
---

<section
  id="top"
  class="relative isolate flex min-h-[100dvh] min-h-[100svh] flex-col justify-end overflow-hidden bg-ink-700"
>
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" data-hero-slideshow>
    {
      slides.map((s, i) => (
        <picture
          class={`hero-slide pointer-events-none absolute inset-0 block h-full w-full transition-opacity duration-[1400ms] ease-[var(--ease-out-soft)] ${i === 0 ? "opacity-100" : "opacity-0"}`}
          data-slide-index={i}
        >
          {s.folder === "happy-faces" ? (
            <img
              src={slideUrl(s.folder, s.slug)}
              alt={s.alt}
              class="hero-slide-img h-full w-full object-cover"
              style={`object-position: ${s.focal || "center"};`}
              loading={i === 0 ? "eager" : "lazy"}
              fetchpriority={i === 0 ? "high" : "auto"}
              decoding="async"
            />
          ) : (
            <>
              <source
                type="image/webp"
                srcset={`${slideUrl(s.folder, s.slug, 1024)} 1024w, ${slideUrl(s.folder, s.slug, 1600)} 1600w, ${slideUrl(s.folder, s.slug, 2400)} 2400w`}
                sizes="100vw"
              />
              <img
                src={slideUrl(s.folder, s.slug)}
                alt={s.alt}
                class="hero-slide-img h-full w-full object-cover"
                style={`object-position: ${s.focal || "center"};`}
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : "auto"}
                decoding="async"
              />
            </>
          )}
        </picture>
      ))
    }
    <!-- Gradient stack: lighter on mobile so the photo breathes; stronger from md+ for readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-ink-700/40 via-ink-700/10 to-ink-700/80 md:from-ink-700/70 md:via-ink-700/35 md:to-ink-700/95" aria-hidden="true" />
    <div class="absolute inset-y-0 left-0 w-full bg-gradient-to-r from-ink-700/30 via-ink-700/10 to-transparent md:w-3/4 md:from-ink-700/60 md:via-ink-700/22" aria-hidden="true" />
  </div>

  <div class="container-x relative z-10 pb-16 pt-32 sm:pb-24 sm:pt-36 md:pb-32 md:pt-44 lg:pt-48">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.22em] text-white/90 drop-shadow-[0_1px_3px_rgba(0,0,0,0.55)] sm:text-[13px]">
        {site.org} · {site.tagline}
      </p>
      <h1 class="h-display mt-5 text-5xl text-white drop-shadow-[0_2px_24px_rgba(0,0,0,0.45)] sm:text-6xl md:text-7xl lg:text-[88px]">
        A space amidst <span class="h-display-italic text-saffron-200">nature.</span>
      </h1>
      <p class="hv-hero-lead mt-6 max-w-xl font-sans text-[15px] font-normal leading-relaxed text-white md:mt-7 md:text-lg">
        Eleven acres of forest near Chandigarh — blessed by Pujya Gurudev Sri Sri Ravi Shankar ji. A
        sanctuary for breath, meditation and seva, open to seekers, families and youth.
      </p>

      <div class="mt-8 grid grid-cols-2 gap-2.5 sm:mt-10 sm:flex sm:flex-wrap sm:items-center sm:gap-3">
        <Button href={`tel:${contact.phoneIntl}`} variant="saffron" size="md" class="w-full justify-center sm:w-auto sm:!px-7 sm:!py-3.5">Call us</Button>
        <Button
          href={wa}
          size="md"
          external
          class="w-full justify-center border border-white/90 bg-white/95 text-ink-700 hover:bg-white sm:w-auto sm:!px-7 sm:!py-3.5"
        >WhatsApp</Button>
        <Button
          href="#yltp"
          size="md"
          class="col-span-2 w-full justify-center border border-white/55 bg-white/10 text-white backdrop-blur-md hover:border-white hover:bg-white/20 sm:w-auto sm:!px-7 sm:!py-3.5"
        >YLTP · {yltp.date}</Button>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center gap-3 text-center text-[11px] uppercase tracking-[0.2em] text-white/90 drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)] sm:mt-14 sm:flex-row sm:flex-wrap sm:items-center sm:justify-start sm:gap-x-10 sm:gap-y-2 sm:text-left sm:text-[12px]">
      <span class="flex items-center justify-center gap-2"><span class="h-px w-6 bg-white/70" /> 11 acres of forest</span>
      <span class="flex items-center justify-center gap-2"><span class="h-px w-6 bg-white/70" /> Bardar · near New Chandigarh</span>
      <span class="flex items-center justify-center gap-2"><span class="h-px w-6 bg-white/70" /> Open to all</span>
    </div>
  </div>

  <div
    class="pointer-events-none absolute bottom-7 right-6 z-10 flex items-center gap-1.5 md:bottom-12 md:right-10"
    data-hero-dots
    aria-hidden="true"
  >
    {
      slides.map((_, i) => (
        <span
          class={`block h-px w-6 bg-white/40 transition-all duration-700 ${i === 0 ? "w-10 bg-white/95" : ""}`}
          data-dot-index={i}
        />
      ))
    }
  </div>

  <a href="#about" aria-label="Scroll to About" class="group absolute bottom-5 left-1/2 z-10 -translate-x-1/2 md:bottom-10">
    <span class="flex h-12 w-7 items-start justify-center rounded-full border border-white/60 p-1.5">
      <span class="h-2 w-px animate-[scrollDot_1.6s_ease-in-out_infinite] bg-white/80"></span>
    </span>
  </a>
</section>

<script>
  const root = document.querySelector<HTMLDivElement>("[data-hero-slideshow]");
  if (root) {
    const slides = root.querySelectorAll<HTMLElement>(".hero-slide");
    const dots = document.querySelectorAll<HTMLElement>("[data-hero-dots] [data-dot-index]");
    let i = 0;
    const total = slides.length;
    const advance = () => {
      const prev = i;
      i = (i + 1) % total;
      slides[prev]?.classList.replace("opacity-100", "opacity-0");
      slides[i]?.classList.replace("opacity-0", "opacity-100");
      dots.forEach((d, di) => {
        d.classList.toggle("bg-white/95", di === i);
        d.classList.toggle("w-10", di === i);
        d.classList.toggle("bg-white/40", di !== i);
      });
    };
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (total > 1) window.setInterval(advance, reduce ? 9000 : 5500);
  }
</script>

<style>
  .hero-slide-img { transform: scale(1.16); transform-origin: center; }
  @media (min-width: 768px) { .hero-slide-img { transform: scale(1.04); } }
  @keyframes scrollDot {
    0%, 20% { transform: translateY(0); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(14px); opacity: 0; }
  }
</style>
