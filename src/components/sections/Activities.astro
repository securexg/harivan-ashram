---
import { activities } from "~/data/site";
---

<section id="activities" class="relative bg-cream-50">
  <div class="container-x py-[var(--section-y)]">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="reveal eyebrow">Recent gatherings</p>
        <h2 class="reveal h-display mt-5 text-4xl text-ink-700 md:text-5xl" style="transition-delay: 60ms">
          A year of breath, <span class="h-display-italic">devotion</span> and seva.
        </h2>
      </div>
      <p class="reveal lead max-w-md text-ink-600" style="transition-delay: 120ms">
        From village satsangs to Vedic homas — Harivan has hosted thousands in community celebration. A
        glimpse of what's been unfolding.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {
        activities.map((a, i) => (
          <article
            class="reveal group flex flex-col overflow-hidden rounded-2xl bg-cream-100 ring-1 ring-ink-100/70 ring-soft"
            style={`transition-delay: ${i * 70}ms`}
          >
            <div class="relative aspect-[5/4] w-full shrink-0 overflow-hidden sm:aspect-[4/3]">
              <img
                src={a.image}
                alt={a.title}
                loading="lazy"
                decoding="async"
                class="hv-cover-img transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                onerror="this.style.background='linear-gradient(135deg,#ebe1cd,#b1c0a2)'; this.style.objectFit='unset'; this.removeAttribute('src');"
              />
              <span class="absolute left-4 top-4 rounded-full border border-cream-50/30 bg-ink-700/40 px-3 py-1 text-[10px] tracking-[0.2em] uppercase text-cream-50 backdrop-blur">
                {a.date}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-6 md:p-7">
              <h3 class="font-serif text-xl text-ink-700 md:text-2xl">{a.title}</h3>
              <p class="mt-3 flex-1 body-text text-sm">{a.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
